{
  "name": "bin_packing",

  "sets": {
    "items": [0,1,2,3],
    "bins": [0,1,2]
  },

  "parameters": {
    "size": [4,5,6,3],
    "capacity": 10
  },

  "variables": [
    {
      "name": "x",
      "sets": ["items","bins"],
      "type": "binary"
    },
    {
      "name": "y",
      "sets": ["bins"],
      "type": "binary"
    }
  ],

  "objective": {
    "sense": "minimize",
    "expr": {
      "sum": {
        "index": "j",
        "set": "bins",
        "expr": {"var": "y", "index": ["j"]}
      }
    }
  },

  "constraints": [

    {
      "forall": {"index":"i","set":"items"},
      "expr": {
        "op":"==",
        "left":{
          "sum":{
            "index":"j",
            "set":"bins",
            "expr":{"var":"x","index":["i","j"]}
          }
        },
        "right":1
      }
    },

    {
      "forall": {"index":"j","set":"bins"},
      "expr":{
        "op":"<=",
        "left":{
          "sum":{
            "index":"i",
            "set":"items",
            "expr":{
              "mul":[
                {"param":"size","index":["i"]},
                {"var":"x","index":["i","j"]}
              ]
            }
          }
        },
        "right":{
          "mul":[
            {"param":"capacity"},
            {"var":"y","index":["j"]}
          ]
        }
      }
    }

  ]
}